{
  "name": "@pixelcoda/headless-nextjs",
  "version": "1.0.3",
  "description": "Production-ready Next.js App Router frontend framework for TYPO3 Headless with PixelCoda compatibility",
  "author": "Casian Blanaru",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CasianBlanaru/Next.js-Front-End-for-TYPO3-Headless.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/CasianBlanaru/Next.js-Front-End-for-TYPO3-Headless#readme",
  "bugs": {
    "url": "https://github.com/CasianBlanaru/Next.js-Front-End-for-TYPO3-Headless/issues"
  },
  "keywords": [
    "typo3",
    "headless",
    "nextjs",
    "pixelcoda",
    "frontend",
    "react",
    "app-router",
    "typo3-headless"
  ],
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.mjs",
      "require": "./dist/components/*.js"
    },
    "./services/*": {
      "types": "./dist/services/*.d.ts",
      "import": "./dist/services/*.mjs",
      "require": "./dist/services/*.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.mjs",
      "require": "./dist/lib/*.js"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "import": "./dist/hooks/*.mjs",
      "require": "./dist/hooks/*.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.mjs",
      "require": "./dist/types/index.js"
    },
    "./config/*": {
      "types": "./dist/config/*.d.ts",
      "import": "./dist/config/*.mjs",
      "require": "./dist/config/*.js"
    },
    "./layouts/*": {
      "types": "./dist/layouts/*.d.ts",
      "import": "./dist/layouts/*.mjs",
      "require": "./dist/layouts/*.js"
    },
    "./registry": {
      "types": "./dist/registry/index.d.ts",
      "import": "./dist/registry/index.mjs",
      "require": "./dist/registry/index.js"
    },
    "./styles": "./dist/styles/globals.css"
  },
  "scripts": {
    "dev": "next dev",
    "build": "tsup src/index.ts --format cjs,esm --dts --outDir dist && next build",
    "start": "next start",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests --testPathIgnorePatterns=e2e",
    "e2e": "playwright test",
    "pack:dry": "npm pack --dry-run"
  },
  "peerDependencies": {
    "next": ">=15.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "defu": "^6.1.7",
    "next": "^16.2.7",
    "ofetch": "^1.5.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ufo": "^1.6.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.7",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.0",
    "postcss": "^8.4.47",
    "ts-jest": "^30.0.0",
    "tailwindcss": "^3.4.14",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3"
  }
}
